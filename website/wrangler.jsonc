{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lumisync",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "lumisync.minlor.net",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  }
}
