# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.wrangler/
/outputs/
/work/
.dev-server.*.log
/.astro/

# The repository's root ignore excludes JSON files; these are source files.
!package.json
!package-lock.json
